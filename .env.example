# MySQL root password (used internally by Docker only)
DB_ROOT_PASSWORD=change_me_root_password

# App database credentials
DB_USER=geo_user
DB_PASSWORD=change_me_strong_password
DB_NAME=geo_app

# JWT signing secret - use a random 64-character string
# Generate one with: openssl rand -hex 32
JWT_SECRET=change_me_64char_random_secret

# Server port (keep as 3001)
PORT=3001

# Set to your actual subdomain, e.g. https://app.yourdomain.com
CLIENT_ORIGIN=https://app.yourdomain.com

NODE_ENV=production
